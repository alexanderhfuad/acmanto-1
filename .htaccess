# Hostinger Shared Hosting Configuration
# Enable rewrite engine
RewriteEngine On

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve static files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Serve static files directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# For SPA routing - redirect all other requests to index.html
# Uncomment this if deploying a single-page application
# RewriteRule ^ /index.html [L]

# For API server - proxy to Node.js application
# Uncomment and configure if deploying the API server
# RewriteRule ^(.*)$ http://localhost:3000/$1 [P,L]
