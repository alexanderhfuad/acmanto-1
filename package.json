{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace @workspace/ac-booking",
    "build:api": "npm run build --workspace @workspace/api-server",
    "dev": "cd artifacts/ac-booking && npm run dev",
    "deploy:hostinger:frontend": "npm run build:frontend",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
